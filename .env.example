# Copy to .env and fill in. Get real Azure values from the team (NOT from group chat).
# .env is gitignored on purpose — never commit it.

# --- Azure AI Foundry (agent developers) ---
AZURE_PROJECT_ENDPOINT=https://your-project.services.ai.azure.com/api/projects/your-project
AZURE_SUBSCRIPTION_ID=your-subscription-id-here
AZURE_RESOURCE_GROUP=your-resource-group-here
MODEL_DEPLOYMENT_NAME=gpt-4.1
DIAGNOSER_AGENT_ID=your-agent-id-here
DIAGNOSER_AGENT_NAME=DIAGNOSER
DIAGNOSER_AGENT_VERSION=11

# --- Simulated target server ---
# 8080 is often blocked on Windows (Hyper-V reserved range) — default to 8090
MOCK_SERVER_HOST=127.0.0.1
MOCK_SERVER_PORT=8090
HEALTH_CHECK_URL=http://127.0.0.1:8090/health
HEALTH_CHECK_INTERVAL_SECONDS=2

# --- Watchman ---
WATCHMAN_POLL_INTERVAL_SEC=3

# --- Logs ---
SERVER_LOG_PATH=logs/server.log

# --- Dashboard ---
DASHBOARD_PORT=5000
